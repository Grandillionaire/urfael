{
  "name": "urfael-app",
  "version": "0.9.0",
  "description": "Urfael, voice overlay, brain daemon, and CLI on Claude Code + Obsidian",
  "author": "MYG Media SRL <contact@myg-media.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "e2e": "node test/e2e.js",
    "security": "node test/security-benchmark.js",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir",
    "fuzz": "node test/fuzz.js",
    "redteam": "node test/redteam.js"
  },
  "build": {
    "appId": "com.urfael.app",
    "productName": "Urfael",
    "artifactName": "${productName}-${arch}.${ext}",
    "afterPack": "packaging/afterPack.js",
    "files": [
      "**/*",
      "!test/**",
      "!**/*.test.js",
      "!packaging/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Urfael"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "icons/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@picovoice/porcupine-node": "^4.0.2",
    "@picovoice/pvrecorder-node": "^1.2.8"
  },
  "bin": {
    "urfael": "./cli.js"
  },
  "engines": {
    "node": ">=20"
  }
}
