# Optional free API keys for live data. Copy to ~/.claude/urfael/api-keys.env and `chmod 600`.
# All have free tiers; none are required. Leave blank to skip that API. NEVER commit the real file.
TAVILY_API_KEY=        # web search — https://tavily.com
COINGECKO_DEMO_KEY=    # crypto prices — https://coingecko.com/en/api
NEWSDATA_API_KEY=      # news — https://newsdata.io
FINNHUB_API_KEY=       # stock quotes — https://finnhub.io
# No-key APIs (weather/Wikipedia/FX/geocoding) work without anything here — see _urfael/apis.md
