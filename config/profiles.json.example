{
  "_comment": "Reference for Urfael permission profiles (the structural sandbox). These are built into app/lib.js (resolveProfile); this file documents them and is a template if you want to tighten them. The daemon maps every /ask to a profile by its `channel`: the local voice overlay sends NO channel and gets `local`; every remote channel (telegram, discord, …) is forced to `untrusted`. resolveProfile is FAIL-CLOSED — any unknown channel resolves to `untrusted`, never `local`.",

  "local": {
    "_for": "the owner at the mic / overlay on this machine",
    "permissionMode": null,
    "_permissionMode": "null = use the daemon default (acceptEdits, or bypassPermissions only if URFAEL_YOLO=1). Reachable ONLY by the local channel.",
    "allowedTools": null,
    "_allowedTools": "null = no restriction (full tool access).",
    "trustFraming": false
  },

  "untrusted": {
    "_for": "anything arriving over a network channel (Telegram/Discord/etc.) — treated as untrusted input",
    "permissionMode": "acceptEdits",
    "_permissionMode": "NEVER bypassPermissions, regardless of URFAEL_YOLO. No unrestricted shell.",
    "allowedTools": ["Read", "Grep", "Glob"],
    "_allowedTools": "READ-ONLY, NO NETWORK EGRESS by default: vault read + search only. Excludes Write/Edit/Bash (git can exec; writes could touch dotfiles/launch agents) AND WebFetch/WebSearch (a network tool turns 'read a local secret' into an exfil channel to any URL). Worst case under injection is echoing a local file back to the OWNER's own chat. --strict-mcp-config also disables all computer-use MCP hands. Deliberate widenings (edit PROFILES in app/lib.js): add 'WebFetch' for web lookup, add 'Write','Edit' for phone capture.",
    "trustFraming": true,
    "_trustFraming": "wraps the message in an untrusted-data envelope so prompt-injection in forwarded content is contained."
  }
}
