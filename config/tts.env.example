# Urfael voice config. Copy to ~/.claude/urfael/tts.env and `chmod 600`. NEVER commit the real file.
#
# DEFAULT = 100% LOCAL / FREE: no API key needed. Voice runs on macOS `say` + local whisper.cpp,
# using only your Claude Code subscription. ElevenLabs/Picovoice below are OPTIONAL upgrades.

# --- providers ---
TTS_PROVIDER=say            # say (default, built-in) | kokoro (local, higher quality) | elevenlabs (paid)
STT_PROVIDER=whispercpp     # whispercpp (default, local) | elevenlabs (paid)

# --- local TTS: macOS `say` (zero-setup) ---
SAY_VOICE=Daniel            # a British male system voice; `say -v '?'` lists installed voices. Blank = system default.
SAY_RATE=190               # words per minute

# --- local STT: whisper.cpp (free, on-device) ---
WHISPER_MODEL=base.en       # base.en (~142MB, default) | small.en (~466MB, better) | tiny.en (fastest)
STT_PORT=8462

# --- local TTS upgrade: Kokoro-FastAPI (optional, higher quality, still free/local) ---
KOKORO_URL=http://localhost:8880/v1/audio/speech
KOKORO_VOICE=bm_george

# Overlay look: sigil | rune | ember | eye  (cycle live with ⌘⇧T)
URFAEL_THEME=sigil

# Instant spoken acknowledgments ("On it, sir.") while a slow answer is being worked out. 0 disables.
URFAEL_ACKS=1

# --- OPTIONAL paid upgrades — leave blank to stay 100% local ---
# ElevenLabs (premium voice) — set TTS_PROVIDER=elevenlabs and/or STT_PROVIDER=elevenlabs to use:
ELEVENLABS_API_KEY=
TTS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb     # a premade ElevenLabs voice (premade voices don't gender-drift)
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_SPEED=1.0
# Picovoice wake word (optional; without it, tap the orb). Free key: console.picovoice.ai
PICOVOICE_ACCESS_KEY=
WAKE_KEYWORD=Computer       # any Porcupine built-in keyword (Computer, Bumblebee, ...)
# WAKE_KEYWORD_PATH=        # custom keyword: train "Urfael" free at console.picovoice.ai → .ppn file path
# WAKE_WORD_LABEL=Urfael    # what the HUD shows in "Say <word>..." (defaults sensibly)

# --- SECURITY: full unrestricted agent is OPT-IN. Leave unset for safe defaults. ---
# URFAEL_YOLO=1   # ⚠️ unrestricted shell — only inside a VM/container. See SECURITY.md.
