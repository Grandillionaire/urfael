<?xml version="1.0" encoding="UTF-8"?>
<!-- Urfael Obsidian auto-heal watchdog — opt-in. install.sh fills {{HOME}}. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.urfael.obsidian-heal</string>
  <key>ProgramArguments</key>
  <array><string>/bin/bash</string><string>{{HOME}}/Urfael/_urfael/obsidian-heal.sh</string></array>
  <key>StartInterval</key><integer>120</integer>
  <key>ThrottleInterval</key><integer>120</integer>
  <key>RunAtLoad</key><true/>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
</dict></plist>
