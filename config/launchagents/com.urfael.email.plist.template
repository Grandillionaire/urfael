<?xml version="1.0" encoding="UTF-8"?>
<!-- Urfael Email bridge — OPT-IN remote access, DRAFT-ONLY (never sends). install.sh fills {{HOME}}/{{NODE}} but does NOT load it.
     Enable only after setting EMAIL_* in ~/.claude/urfael/bridge.env (incl. EMAIL_ALLOWED_SENDERS — the From allowlist).
     Read SECURITY.md first. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.urfael.email</string>
  <key>ProgramArguments</key>
  <array><string>{{NODE}}</string><string>{{REPO}}/app/bridge/email-bridge.js</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><dict><key>SuccessfulExit</key><false/></dict>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
  <key>StandardOutPath</key><string>{{HOME}}/.claude/urfael/email.out.log</string>
  <key>StandardErrorPath</key><string>{{HOME}}/.claude/urfael/email.err.log</string>
</dict></plist>
